{
  "name": "@null-protocol/server",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "node ../../node_modules/esbuild/bin/esbuild src/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.js",
    "dev": "yarn build && node ./dist/index.js",
    "start": "node ./dist/index.js",
    "lint": "eslint . --ext .ts",
    "test": "jest --config ./jest.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@null-protocol/engine": "workspace:*",
    "@null-protocol/scenario-kit": "workspace:*"
  },
  "devDependencies": {
    "@null-protocol/eslint-config": "workspace:*"
  }
}
